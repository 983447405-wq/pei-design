{
  "name": "pei-design",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "description": "AI Product Designer and UI/UX Designer portfolio, blog, and resource content hub.",
  "scripts": {
    "dev": "next dev --host 127.0.0.1",
    "build": "next build",
    "start": "next start --host 127.0.0.1",
    "lint": "eslint app components content lib --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
